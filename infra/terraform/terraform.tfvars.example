# Copy to terraform.tfvars and adjust. The real terraform.tfvars is gitignored.

aws_region           = "eu-west-2"
availability_zone    = "eu-west-2a"

server_instance_type = "t3.small"   # 2 GiB. Bump the server to t3.medium if you run kube-prometheus-stack on it.
agent_instance_type  = "t3.small"
agent_count          = 2

root_volume_size     = 20
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"

# my_ip = "203.0.113.42"   # optional — auto-detected from the machine running terraform if omitted
